# Gil's FlowDesk — 환경변수 예시
# docker-compose.yml과 함께 사용
# 실제 사용 시: cp .env.example .env 후 수정

# ═══ 필수 ═══
DB_PASSWORD=please_change_this_to_a_strong_password

# ═══ 선택 ═══
# 외부 공개 포트 (기본 8888)
PORT=8888

# 시놀로지 작업 폴더 경로 (호스트 경로)
# 예: /volume1/Workspace, /volume1/homes/myuser/workspace
# 컨테이너 내부에서는 /workspace 로 마운트됨
WORKSPACE_HOST=/volume1/docker/gils-flowdesk/workspace
