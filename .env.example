# Gil's FlowDesk — 환경변수 예시
# 사용법: cp .env.example .env 후 수정
# 모든 경로는 시놀로지/호스트 기준 절대경로

# ═══════════════════════════════════════
# 필수 설정
# ═══════════════════════════════════════

# DB 비밀번호 (반드시 변경)
DB_PASSWORD=please_change_this_to_a_strong_password

# ═══════════════════════════════════════
# 선택 설정 (기본값 사용해도 됨)
# ═══════════════════════════════════════

# 외부 공개 포트 (시놀로지 기본: 9090 권장)
# 시놀로지에서 피해야 할 포트: 5000/5001(DSM), 80/443(Web Station)
PORT=9090

# ═══════════════════════════════════════
# 데이터 저장 경로 (시놀로지 파일 시스템)
# ═══════════════════════════════════════
# 아래 경로들을 미리 시놀로지에 만들어두세요:
#   mkdir -p /volume1/FlowDesk/{db,workspace,creds,uploads}
#
# 지정 안 하면 Docker 내부 volume에 저장됨 (파일 탐색기에서 접근 불가)

# PostgreSQL 데이터 (중요: 용량 커질 수 있음, SSD 볼륨 권장)
DB_DATA_HOST=/volume1/FlowDesk/db

# 작업 폴더 — 각 노드(Agent)가 파일 읽기/쓰기할 공간
# 컨테이너 내부에서는 /workspace 로 보임
WORKSPACE_HOST=/volume1/FlowDesk/workspace

# Claude 인증 파일 저장 (active 계정 1개용 — 글로벌 ~/.claude)
CLAUDE_CREDS_HOST=/volume1/FlowDesk/creds

# Gemini 인증 파일 저장 (API 키 / OAuth 토큰 — 글로벌 ~/.gemini)
GEMINI_CREDS_HOST=/volume1/FlowDesk/gemini-creds

# 멀티계정 CLI 런타임 디렉터리 (계정별 격리 + 토큰 갱신 영속)
# 이 두 경로를 마운트하지 않으면:
#   - Claude/Gemini CLI가 액세스 토큰 갱신 시 컨테이너 /tmp에 쓰고
#   - 컨테이너 재시작 시 그 갱신본이 휘발돼 인증 실패가 반복됨
# 시놀로지에 미리 mkdir 해두면 됩니다:
#   mkdir -p /volume1/FlowDesk/{accts-runtime,gmini-accts-runtime}
#   chown -R 1000:1000 /volume1/FlowDesk/accts-runtime /volume1/FlowDesk/gmini-accts-runtime
ACCTS_RUNTIME_HOST=/volume1/FlowDesk/accts-runtime
GMINI_RUNTIME_HOST=/volume1/FlowDesk/gmini-accts-runtime

# 업로드 이미지/PDF 저장
UPLOADS_HOST=/volume1/FlowDesk/uploads

# ═══════════════════════════════════════
# 시놀로지 임의 폴더 접근 (선택)
# ═══════════════════════════════════════
# 컨테이너의 /synology 로 마운트되는 시놀로지 호스트 폴더
# 노드 작업폴더(CWD)에 /synology/하위폴더/... 식으로 자유롭게 접근 가능
#
# 예시:
#   SYNOLOGY_ROOT=/volume1                  → 시놀로지 전체
#   SYNOLOGY_ROOT=/volume1/00_Gils_Project  → 특정 작업 폴더만 (권장)
#   SYNOLOGY_ROOT=/volume1/공유폴더         → 공유 폴더 한정
#
# 권한 주의: chown -R 1000:1000 <경로> 로 컨테이너 사용자(uid 1000)가 쓸 수 있게 해야 함
SYNOLOGY_ROOT=/volume1

# ═══════════════════════════════════════
# YouTube 검색 (선택)
# ═══════════════════════════════════════
# YouTube Data API v3 키 — 검색 기능 쓸 때만 필요
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
# 무료 할당량: 10,000 units/일 (검색 1회 ~ 100 units)
YOUTUBE_API_KEY=

# ═══════════════════════════════════════
# Whisper 모델 (선택)
# ═══════════════════════════════════════
# 자막 생성용 faster-whisper 모델 크기
#   tiny(75MB, 빠름 낮음) / base(142MB) / small(466MB, 권장) / medium(1.5GB) / large-v3(2.9GB)
WHISPER_MODEL=small
# Whisper 모델 캐시 영속화 (첫 다운 후 재사용)
WHISPER_CACHE_HOST=/volume1/FlowDesk/whisper-cache

# ═══════════════════════════════════════
# 외부 DB 사용 (고급)
# ═══════════════════════════════════════
# 별도의 PostgreSQL 서버를 이미 돌리고 있다면:
# DB_HOST=postgres.mynas.local
# DB_PORT=5432
# DB_NAME=canvas_db
# DB_USER=canvas
# 그리고 docker-compose.yml에서 postgres 서비스는 주석 처리
